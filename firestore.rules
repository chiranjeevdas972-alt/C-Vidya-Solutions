rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. Reusable validation helpers (MUST be placed before match blocks in the scope)
    function isValidInquiry(data) {
      return data != null
        && data['id'] is string && data['id'].size() <= 128
        && data['name'] is string && data['name'].size() > 0 && data['name'].size() <= 150
        && data['email'] is string && data['email'].size() > 0 && data['email'].size() <= 200
        && data['phone'] is string && data['phone'].size() > 0 && data['phone'].size() <= 50
        && data['service'] is string && data['service'].size() <= 200
        && data['message'] is string && data['message'].size() <= 5000
        && data['status'] is string && data['status'].size() <= 100
        && data['timestamp'] is string && data['timestamp'].size() <= 100;
    }

    // 2. Default deny catch-all match block
    match /{document=**} {
      allow read, write: if false;
    }

    // 3. Match rules for collections
    match /inquiries/{inquiryId} {
      // Allow any visitor to submit callback inquiries, validating strict static properties and preventing shadow fields
      allow create: if request.resource.data != null
        && request.resource.data.keys().size() == 8
        && 'id' in request.resource.data
        && 'name' in request.resource.data
        && 'email' in request.resource.data
        && 'phone' in request.resource.data
        && 'service' in request.resource.data
        && 'message' in request.resource.data
        && 'status' in request.resource.data
        && 'timestamp' in request.resource.data
        && isValidInquiry(request.resource.data);
      
      // Let existing leads be readable for local management and reporting
      allow read: if true;
      
      // Prevent editing or deletion once submitted
      allow update, delete: if false;
    }
  }
}
